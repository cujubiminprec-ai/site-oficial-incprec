  "name": "inprec-monolith",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "vite build",
    "build:app": "npm run build && npm run build:server",
    "build:server": "tsc --project tsconfig.server.json && node scripts/prepare-server-dist.cjs",
    "dev": "concurrently \"npm run dev:server\" \"vite\"",
    "dev:server": "npm run build:server && node dist/server.js",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "migrate": "npm run build:server && node dist/db/migrate.js",
    "seed": "npm run build:server && node dist/db/seed.js",
    "setup": "npm run migrate && npm run seed",
    "reset-admin": "npm run build:server && node dist/db/reset-admin.js",
    "type-check": "tsc --noEmit --project tsconfig.app.json"
  },
  "type": "module",
  "version": "0.0.0"
}
