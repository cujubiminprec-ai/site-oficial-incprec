{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "strictPropertyInitialization": false,
    "noImplicitThis": false,
    "useUnknownInCatchVariables": false,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": false,
    "noUncheckedSideEffectImports": false,
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/views/components/*"],
      "@/contexts/*": ["./src/views/contexts/*"],
      "@/hooks/*": ["./src/views/hooks/*"],
      "@/i18n/*": ["./src/views/i18n/*"],
      "@/mocks/*": ["./src/views/mocks/*"],
      "@/pages/*": ["./src/views/pages/*"],
      "@/router/*": ["./src/views/router/*"],
    }
  },
  "include": ["src/views", "src/services", "src/utils/cookies.ts", "src/utils/documentViewer.ts", "src/utils/gestoresData.ts", "src/utils/uploadFolders.ts", "vite-env.d.ts"]
}
