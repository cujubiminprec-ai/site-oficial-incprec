{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "ignoreDeprecations": "5.0",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/server.ts",
    "src/config/**/*.ts",
    "src/controllers/**/*.ts",
    "src/db/**/*.ts",
    "src/middleware/**/*.ts",
    "src/models/**/*.ts",
    "src/types/**/*.ts",
    "src/utils/app-config.ts",
    "src/utils/protocolo.ts"
  ],
  "exclude": ["node_modules", "dist", "src/views", "src/services"]
}
